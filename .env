# ══════════════════════════════════════════════════════════
#  Livermore Co-Pilot Backend — Environment Variables
#  Copy this to .env for local dev, or set in Railway dashboard
#  NEVER commit .env to git — add it to .gitignore
# ══════════════════════════════════════════════════════════

# ── Stripe ─────────────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY_HERE

# Get from: dashboard.stripe.com → Developers → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Get from: dashboard.stripe.com → Products → your product → Price IDs
STRIPE_MONTHLY_PRICE_ID=price_YOUR_MONTHLY_PRICE_ID
STRIPE_ANNUAL_PRICE_ID=price_YOUR_ANNUAL_PRICE_ID

# ── Google OAuth ────────────────────────────────────────────
# Get from: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com

# ── App ─────────────────────────────────────────────────────
# Your Railway deployment URL (set after first deploy)
FRONTEND_URL=https://your-app.railway.app

# Port (Railway sets this automatically, leave as 3000 for local)
PORT=3000
